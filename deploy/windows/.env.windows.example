APP_NAME=aegis
APP_ENV=development
HTTP_PORT=8088
ADMIN_API_TOKEN=change-admin-token
READ_TIMEOUT=5s
WRITE_TIMEOUT=10s
SHUTDOWN_TIMEOUT=10s

JWT_SECRET=change-me
JWT_ISSUER=aegis
JWT_TTL=720h
JWT_REFRESH_TTL=168h

POSTGRES_DSN=postgres://aegis:aegis@127.0.0.1:5432/aegis?sslmode=disable
POSTGRES_MAX_CONNS=10
POSTGRES_MIN_CONNS=2
POSTGRES_MAX_CONN_LIFETIME=30m

LEGACY_MYSQL_DSN=root:password@tcp(127.0.0.1:3306)/usersystem?charset=utf8mb4&parseTime=true&loc=Local
LEGACY_MYSQL_BATCH_SIZE=500

REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=aegis

NATS_URL=nats://127.0.0.1:4222
NATS_STREAM_NAME=AEGIS_EVENTS

TEMPORAL_HOST_PORT=127.0.0.1:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=aegis-workflow
TEMPORAL_WORKFLOW_EXECUTION_TIMEOUT=720h
TEMPORAL_WORKFLOW_RUN_TIMEOUT=24h
TEMPORAL_WORKFLOW_TASK_TIMEOUT=30s
TEMPORAL_ACTIVITY_TIMEOUT=30s

AUTO_SIGN_ENABLED=true
AUTO_SIGN_TIMEZONE=Asia/Shanghai
AUTO_SIGN_TICK_INTERVAL=1m
AUTO_SIGN_REBUILD_INTERVAL=15m
AUTO_SIGN_BATCH_SIZE=200
AUTO_SIGN_RETRY_DELAY=5m

OAUTH_QQ_CLIENT_ID=
OAUTH_QQ_CLIENT_SECRET=
OAUTH_QQ_REDIRECT_URL=http://localhost:8088/api/auth/oauth2/callback?provider=qq
OAUTH_WECHAT_CLIENT_ID=
OAUTH_WECHAT_CLIENT_SECRET=
OAUTH_WECHAT_REDIRECT_URL=http://localhost:8088/api/auth/oauth2/callback?provider=wechat
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_GITHUB_REDIRECT_URL=http://localhost:8088/api/auth/oauth2/callback?provider=github
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GOOGLE_REDIRECT_URL=http://localhost:8088/api/auth/oauth2/callback?provider=google
OAUTH_MICROSOFT_CLIENT_ID=
OAUTH_MICROSOFT_CLIENT_SECRET=
OAUTH_MICROSOFT_REDIRECT_URL=http://localhost:8088/api/auth/oauth2/callback?provider=microsoft
OAUTH_WEIBO_CLIENT_ID=
OAUTH_WEIBO_CLIENT_SECRET=
OAUTH_WEIBO_REDIRECT_URL=http://localhost:8088/api/auth/oauth2/callback?provider=weibo
