APP_NAME=aegis
APP_ENV=development
HTTP_PORT=8088
ADMIN_API_TOKEN=change-admin-token
ADMIN_BOOTSTRAP_ACCOUNT=superadmin
ADMIN_BOOTSTRAP_PASSWORD=AegisAdmin@2026!
ADMIN_BOOTSTRAP_DISPLAY_NAME=Super Administrator
ADMIN_BOOTSTRAP_EMAIL=admin@aegis.local
APP_DEFAULT_IANA_TIMEZONE=Asia/Shanghai
READ_TIMEOUT=5s
WRITE_TIMEOUT=10s
SHUTDOWN_TIMEOUT=10s

JWT_SECRET=change-me
JWT_ISSUER=aegis
JWT_TTL=720h
JWT_REFRESH_TTL=168h
BILL_EXPORT_FONT_PATH=

POSTGRES_DSN=postgres://aegis:aegis@postgres:5432/aegis?sslmode=disable
POSTGRES_SESSION_TIMEZONE=UTC
POSTGRES_MAX_CONNS=10
POSTGRES_MIN_CONNS=2
POSTGRES_MAX_CONN_LIFETIME=30m

LEGACY_MYSQL_DSN=root:password@tcp(127.0.0.1:3306)/usersystem?charset=utf8mb4&parseTime=true&loc=Local
LEGACY_MYSQL_BATCH_SIZE=500

REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=aegis

PAYMENT_BILL_EXPORT_ROOT_DIR=data/payment-bills
PAYMENT_BILL_EXPORT_TTL=30m
PAYMENT_BILL_EXPORT_CLEANUP_INTERVAL=5m

ADMIN_USER_SEARCH_ROOT_DIR=data/search
ADMIN_USER_SEARCH_BATCH_SIZE=2000
ADMIN_USER_SEARCH_MAX_PINYIN_PATHS=16
ADMIN_USER_SEARCH_WARMUP_ENABLED=true
ADMIN_USER_SEARCH_WARMUP_CONCURRENCY=2

ACCOUNT_BAN_CLEANUP_ENABLED=true
ACCOUNT_BAN_CLEANUP_SPEC=@every 1m
ACCOUNT_BAN_CLEANUP_BATCH_SIZE=200

RISK_IP_REPUTATION_PROVIDER=none
RISK_IP_REPUTATION_CACHE_TTL=6h
RISK_IP_REPUTATION_TIMEOUT=1500ms
RISK_IP_REPUTATION_ALLOW_STALE=true
RISK_IPQUALITYSCORE_API_KEY=
RISK_IPQUALITYSCORE_BASE_URL=https://www.ipqualityscore.com/api/json/ip
RISK_IPQUALITYSCORE_STRICTNESS=1
RISK_IPQUALITYSCORE_FAST=true
RISK_IPQUALITYSCORE_MOBILE=false
RISK_IPQUALITYSCORE_LIGHTER_PENALTIES=false
RISK_RATE_LIMIT_ENABLED=false
RISK_RATE_LIMIT_IP_PER_MINUTE=120
RISK_RATE_LIMIT_ACCOUNT_PER_MINUTE=30
RISK_RATE_LIMIT_DEVICE_PER_MINUTE=60
RISK_RATE_LIMIT_ACCOUNT_DEVICE_PER_MINUTE=20

NATS_URL=nats://nats:4222
NATS_STREAM_NAME=AEGIS_EVENTS

TEMPORAL_HOST_PORT=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=aegis-workflow
TEMPORAL_WORKFLOW_EXECUTION_TIMEOUT=720h
TEMPORAL_WORKFLOW_RUN_TIMEOUT=24h
TEMPORAL_WORKFLOW_TASK_TIMEOUT=30s
TEMPORAL_ACTIVITY_TIMEOUT=30s

AUTO_SIGN_ENABLED=true
AUTO_SIGN_TIMEZONE=Asia/Shanghai
AUTO_SIGN_TICK_INTERVAL=1m
AUTO_SIGN_REBUILD_INTERVAL=15m
AUTO_SIGN_BATCH_SIZE=200
AUTO_SIGN_RETRY_DELAY=5m

OAUTH_QQ_CLIENT_ID=
OAUTH_QQ_CLIENT_SECRET=
OAUTH_QQ_REDIRECT_URL=http://localhost:8088/api/auth/oauth2/callback?provider=qq
OAUTH_WECHAT_CLIENT_ID=
OAUTH_WECHAT_CLIENT_SECRET=
OAUTH_WECHAT_REDIRECT_URL=http://localhost:8088/api/auth/oauth2/callback?provider=wechat
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_GITHUB_REDIRECT_URL=http://localhost:8088/api/auth/oauth2/callback?provider=github
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GOOGLE_REDIRECT_URL=http://localhost:8088/api/auth/oauth2/callback?provider=google
OAUTH_MICROSOFT_CLIENT_ID=
OAUTH_MICROSOFT_CLIENT_SECRET=
OAUTH_MICROSOFT_REDIRECT_URL=http://localhost:8088/api/auth/oauth2/callback?provider=microsoft
OAUTH_WEIBO_CLIENT_ID=
OAUTH_WEIBO_CLIENT_SECRET=
OAUTH_WEIBO_REDIRECT_URL=http://localhost:8088/api/auth/oauth2/callback?provider=weibo


